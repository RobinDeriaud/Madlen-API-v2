generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ADMIN AUTH (table indépendante)
// ============================================================

/// Administrateurs du dashboard — table: admin_users
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("admin_users")
}

// ============================================================
// ENUMS
// ============================================================

enum UserType {
  NONE      @map("null")
  PATIENT   @map("patient")
  PRATICIEN @map("praticien")
}

enum Sexe {
  FEMININ  @map("féminin")
  MASCULIN @map("masculin")
}

enum Recurrence {
  FAIBLE  @map("faible")
  MOYENNE @map("moyenne")
  HAUTE   @map("haute")
}

enum ReponseElement {
  NULL @map("null")
  OUI  @map("oui")
  NON  @map("non")
}

enum OutilExercice {
  SPECTROGRAMME @map("spectrogramme")
  PROSODIE      @map("prosodie")
  PUISSANCE     @map("puissance")
  IMAGE         @map("image")
  DIADO         @map("diado")
  PHONEME       @map("phoneme")
  PHONETOGRAMME @map("phonetogramme")
  MOTS          @map("mots")
  TRAITS        @map("traits")
  PRAXIES       @map("praxies")
  CHOIX         @map("choix")
  VIDEO         @map("video")
  LIEN          @map("lien")
  HISTOGRAMME   @map("histogramme")
}

enum MacroExercice {
  AJUSTEMENT_100
  HYGIENE_PHONATOIRE_200
  PRAXIES_300
  RENDEMENT_VOCAL_400
  FLEXIBILITE_VOCALE_500
  INTELLIGIBILITE_600
  FLUENCE_700
}

enum AxeExercice {
  AJUSTEMENT_100
  REGULATION_ECHANGES_130
  POSTURE_140
  HYGIENE_ALIMENTAIRE_210
  ECONOMIE_VOCALE_220
  ECHAUFFEMENT_RECUPERATION_230
  EXERCICES_SPECIFIQUES_240
  PROPRIOCEPTION_ARTICULATOIRE_310
  PRAXIES_SIMPLES_320
  PRAXIES_COORDONNEES_330
  RESPIRATION_410
  RESPIRATION_AVANCEE_420
  TONICITE_LABIALE_430
  TONICITE_VELAIRE_440
  TONICITE_LINGUALE_450
  CONTROLE_HAUTEUR_510
  PASSAGES_MECANISMES_520
  CONTROLE_INTENSITE_530
  DISSOCIATION_PARAMETRES_540
  DYNAMIQUE_VOCALE_550
  PRODUCTION_VOYELLES_610
  PRODUCTION_CONSONNES_620
  SYLLABES_PROCESSUS_630
  TRAVAIL_PROSODIE_640
  DIADOCOCINETIQUES_CONSONANTIQUES_710
  DIADOCOCINETIQUES_VOCALIQUES_720
  DIADOCOCINETIQUES_COORDONNEES_730
  DIADOCOCINETIQUES_MOTS_740
  PHRASES_FONCTIONNELLES_750
}

// ============================================================
// MODÈLES
// ============================================================

/// Utilisateurs de l'application — table: users
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  nom          String?
  prenom       String?
  confirmed    Boolean  @default(false)
  user_type    UserType @default(NONE) @map("user_type")

  profil_patient   Patient?
  profil_praticien Praticien?

  @@map("users")
}

/// Praticien — table: praticiens
model Praticien {
  id           Int       @id @default(autoincrement())
  numero_adeli String?   @map("numero_adeli")
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  userId Int?  @unique @map("users_permissions_user_id")
  user   User? @relation(fields: [userId], references: [id])

  /// Liste des patients suivis par ce praticien
  patients Patient[]

  @@map("praticiens")
}

/// Patient — table: patients
model Patient {
  id          Int       @id @default(autoincrement())
  age         Int?
  sexe        Sexe?
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userId Int?  @unique @map("users_permissions_user_id")
  user   User? @relation(fields: [userId], references: [id])

  /// Praticien référent (un seul par patient)
  praticienId Int?       @map("praticien_id")
  praticien   Praticien? @relation(fields: [praticienId], references: [id])

  /// Listes d'exercices prescrites à ce patient
  listes Liste[]

  @@map("patients")
}

/// Liste d'exercices prescrite à un patient — table: listes
model Liste {
  id        Int       @id @default(autoincrement())
  nom       String?
  date      DateTime? @db.Date
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  /// Patient à qui appartient cette liste
  patientId Int     @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id])

  /// Exercices référencés par cette liste (many-to-many implicite)
  exercices Exercice[]

  @@map("listes")
}

/// Exercice indépendant — table: exercices
model Exercice {
  id           Int            @id @default(autoincrement())
  numero       Int?           @unique
  nom          String?
  sigle        String?
  bref         String?
  but          String?
  instructions String?
  astuce       String?
  commentaires String?
  axe          AxeExercice?
  macro        MacroExercice?
  outil        OutilExercice?
  outil_param  String?        @map("outil_param")
  duree        Int            @default(2)
  recurrence   Recurrence?
  auteur       String?
  version      String?
  date         DateTime?      @db.Date
  boutons      Json?
  fichier      String?
  publishedAt  DateTime?      @map("published_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  /// Listes qui référencent cet exercice (relation implicite, non exposée en API)
  listes Liste[]

  /// Items de checklist propres à cet exercice (ex: réponses oui/non)
  listeElements ListeElement[]

  @@map("exercices")
}

/// Checklist d'items associée à un exercice — table: liste_elements
model ListeElement {
  id      Int             @id @default(autoincrement())
  element String?
  reponse ReponseElement? @default(NULL)
  order   Int?            @map("field_order")

  exerciceId Int?      @map("exercice_id")
  exercice   Exercice? @relation(fields: [exerciceId], references: [id])

  @@map("liste_elements")
}

/// Page de contenu statique — table: page_statiques
model PageStatique {
  id            Int       @id @default(autoincrement())
  nom           String?
  slug          String?
  contenu       String?
  date_modified DateTime? @map("date_modified") @db.Date
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("page_statiques")
}
