generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ADMIN AUTH (table indépendante de Strapi)
// ============================================================

/// Administrateurs du dashboard — table: users
model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("users")
}

// ============================================================
// ENUMS (Strapi)
// ============================================================

enum UserType {
  NONE      @map("null")
  PATIENT   @map("patient")
  PRATICIEN @map("praticien")
}

enum Sexe {
  FEMININ  @map("féminin")
  MASCULIN @map("masculin")
}

enum ReponseElement {
  NULL @map("null")
  OUI  @map("oui")
  NON  @map("non")
}

enum Recurrence {
  FAIBLE  @map("faible")
  MOYENNE @map("moyenne")
  HAUTE   @map("haute")
}

enum OutilExercice {
  SPECTROGRAMME @map("spectrogramme")
  PROSODIE      @map("prosodie")
  PUISSANCE     @map("puissance")
  IMAGE         @map("image")
  DIADO         @map("diado")
  PHONEME       @map("phoneme")
  PHONETOGRAMME @map("phonetogramme")
  MOTS          @map("mots")
  TRAITS        @map("traits")
  PRAXIES       @map("praxies")
  CHOIX         @map("choix")
  VIDEO         @map("video")
  LIEN          @map("lien")
  HISTOGRAMME   @map("histogramme")
}

enum MacroExercice {
  AJUSTEMENT_100
  HYGIENE_PHONATOIRE_200
  PRAXIES_300
  RENDEMENT_VOCAL_400
  FLEXIBILITE_VOCALE_500
  INTELLIGIBILITE_600
  FLUENCE_700
}

enum AxeExercice {
  AJUSTEMENT_100
  REGULATION_ECHANGES_130
  POSTURE_140
  HYGIENE_ALIMENTAIRE_210
  ECONOMIE_VOCALE_220
  ECHAUFFEMENT_RECUPERATION_230
  EXERCICES_SPECIFIQUES_240
  PROPRIOCEPTION_ARTICULATOIRE_310
  PRAXIES_SIMPLES_320
  PRAXIES_COORDONNEES_330
  RESPIRATION_410
  RESPIRATION_AVANCEE_420
  TONICITE_LABIALE_430
  TONICITE_VELAIRE_440
  TONICITE_LINGUALE_450
  CONTROLE_HAUTEUR_510
  PASSAGES_MECANISMES_520
  CONTROLE_INTENSITE_530
  DISSOCIATION_PARAMETRES_540
  DYNAMIQUE_VOCALE_550
  PRODUCTION_VOYELLES_610
  PRODUCTION_CONSONNES_620
  SYLLABES_PROCESSUS_630
  TRAVAIL_PROSODIE_640
  DIADOCOCINETIQUES_CONSONANTIQUES_710
  DIADOCOCINETIQUES_VOCALIQUES_720
  DIADOCOCINETIQUES_COORDONNEES_730
  DIADOCOCINETIQUES_MOTS_740
  PHRASES_FONCTIONNELLES_750
}

// ============================================================
// MODÈLES STRAPI
// ============================================================

/// plugin::users-permissions.user → table: up_users
model User {
  id                Int       @id @default(autoincrement())
  documentId        String    @unique @map("document_id")
  username          String    @unique
  email             String    @unique
  password          String?
  nom               String?
  prenom            String?
  provider          String?
  confirmed         Boolean   @default(false)
  blocked           Boolean   @default(false)
  profile_completed Boolean   @default(false) @map("profile_completed")
  user_type         UserType  @default(NONE) @map("user_type")
  publishedAt       DateTime? @map("published_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  profil_patient   Patient?
  profil_praticien Praticien?

  @@map("up_users")
}

/// api::patient.patient → table: patients
model Patient {
  id          Int       @id @default(autoincrement())
  documentId  String    @unique @map("document_id")
  age         Int?
  sexe        Sexe?
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userId Int?  @unique @map("users_permissions_user_id")
  user   User? @relation(fields: [userId], references: [id])

  suivi_patients SuiviPatient[]

  @@map("patients")
}

/// api::praticien.praticien → table: praticiens
model Praticien {
  id           Int       @id @default(autoincrement())
  documentId   String    @unique @map("document_id")
  numero_adeli String?   @map("numero_adeli")
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  userId Int?  @unique @map("users_permissions_user_id")
  user   User? @relation(fields: [userId], references: [id])

  suivi_patients      SuiviPatient[]
  prescriptions_crees Prescription[] @relation("praticien_creator")

  @@map("praticiens")
}

/// api::exercice.exercice → table: exercices
model Exercice {
  id           Int            @id @default(autoincrement())
  documentId   String         @unique @map("document_id")
  numero       Int?           @unique
  nom          String?
  sigle        String?
  bref         String?
  but          String?
  instructions String?
  astuce       String?
  commentaires String?
  axe          AxeExercice?
  macro        MacroExercice?
  outil        OutilExercice?
  outil_param  String?        @map("outil_param")
  duree        Int            @default(2)
  recurrence   Recurrence?
  auteur       String?
  version      String?
  date         DateTime?      @db.Date
  boutons      Json?
  fichier      String?
  publishedAt  DateTime?      @map("published_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  liste             ListeElement[]
  exercice_elements ExerciceElement[]
  parcours_elements ParcoursElement[]

  @@map("exercices")
}

/// api::suivi-patient.suivi-patient → table: suivi_patients
model SuiviPatient {
  id             Int       @id @default(autoincrement())
  documentId     String    @unique @map("document_id")
  actif          Boolean?
  archived       Boolean?
  isConfirmed    Boolean?  @map("is_confirmed")
  dateDebutSuivi DateTime? @map("date_debut_suivi") @db.Date
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  patientId   Int?       @map("patient_id")
  patient     Patient?   @relation(fields: [patientId], references: [id])
  praticienId Int?       @map("praticien_id")
  praticien   Praticien? @relation(fields: [praticienId], references: [id])

  prescriptions Prescription[]

  @@map("suivi_patients")
}

/// api::prescription.prescription → table: prescriptions
model Prescription {
  id               Int       @id @default(autoincrement())
  documentId       String    @unique @map("document_id")
  deliveredAt      DateTime? @map("delivered_at") @db.Date
  exercicesParJour Int?      @map("exercices_par_jour")
  isActive         Boolean?  @map("is_active")
  publishedAt      DateTime? @map("published_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  praticienCreatorId Int?       @map("praticien_creator_id")
  praticien_creator  Praticien? @relation("praticien_creator", fields: [praticienCreatorId], references: [id])

  suiviPatientId Int?          @map("suivi_patient_id")
  suivi_patient  SuiviPatient? @relation(fields: [suiviPatientId], references: [id])

  exercices ExerciceElement[]
  parcours  Parcours[]

  @@map("prescriptions")
}

/// api::page-statique.page-statique → table: page_statiques
model PageStatique {
  id            Int       @id @default(autoincrement())
  documentId    String    @unique @map("document_id")
  nom           String?
  slug          String?
  contenu       String?
  date_modified DateTime? @map("date_modified") @db.Date
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("page_statiques")
}

// ============================================================
// COMPOSANTS STRAPI (tables séparées)
// ============================================================

/// element.exercice-element → table: components_element_exercice_elements
model ExerciceElement {
  id         Int  @id @default(autoincrement())
  repetition Int?
  order      Int? @map("field_order")

  exerciceId Int?      @map("exercice_id")
  exercice   Exercice? @relation(fields: [exerciceId], references: [id])

  prescriptionId Int?          @map("prescription_id")
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])

  @@map("components_element_exercice_elements")
}

/// element.liste-element → table: components_element_liste_elements
model ListeElement {
  id      Int             @id @default(autoincrement())
  element String?
  reponse ReponseElement? @default(NULL)
  order   Int?            @map("field_order")

  exerciceId Int?      @map("exercice_id")
  exercice   Exercice? @relation(fields: [exerciceId], references: [id])

  @@map("components_element_liste_elements")
}

/// element.parcours-element → table: components_element_parcours_elements
model ParcoursElement {
  id     Int      @id @default(autoincrement())
  isDone Boolean? @map("is_done")
  order  Int?     @map("field_order")

  exerciceId Int?      @map("exercice_id")
  exercice   Exercice? @relation(fields: [exerciceId], references: [id])

  parcoursId Int?      @map("parcours_id")
  parcours   Parcours? @relation(fields: [parcoursId], references: [id])

  @@map("components_element_parcours_elements")
}

/// liste.parcours → table: components_liste_parcours
model Parcours {
  id     Int       @id @default(autoincrement())
  date   DateTime? @db.Date
  isDone Boolean?  @map("is_done")
  order  Int?      @map("field_order")

  prescriptionId Int?          @map("prescription_id")
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])

  exercices ParcoursElement[]

  @@map("components_liste_parcours")
}
